{
    "name": "streamdeck-sonos",
    "version": "1.1.0",
    "scripts": {
        "build": "rollup -c",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.pavel-karpovich.sonos\"",
        "validate": "streamdeck validate com.pavel-karpovich.sonos.sdPlugin",
        "pack": "streamdeck bundle com.pavel-karpovich.sonos.sdPlugin",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "type": "module",
    "devDependencies": {
        "@elgato/cli": "^1.7.4",
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@tsconfig/node24": "^24.0.4",
        "@types/node": "^26.0.0",
        "prettier": "^3.8.4",
        "rollup": "^4.62.2",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "@elgato/streamdeck": "^2.1.0",
        "@svrooij/sonos": "^2.5.0",
        "axios": "^1.18.0",
        "bonjour-service": "^1.4.1"
    }
}
